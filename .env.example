APP_NAME=ai-service
APP_PORT=8091
# 旋钮：glm | deepseek | claude | openai
# 本专栏从 M01 起聊天实际走 OPENAI_*（讯飞等兼容网关）→ 默认 openai
# 若仍写 DEFAULT_LLM=glm 但未配真智谱 Key，工厂会回退到 OPENAI_*
DEFAULT_LLM=openai

# --- 原链路（必配，05.01/05.02 默认聊天）---
OPENAI_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
OPENAI_API_KEY=你的完整APIKey
OPENAI_MODEL=sensen-code-latest

# --- glm（智谱，可选；不要把讯飞 Key 填到这里）---
# ZHIPUAI_API_KEY=YOUR_ZHIPU_API_KEY
# ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4-flash

# --- deepseek（可选）---
# DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# --- claude（可选）：二选一 ---
# CLAUDE_BASE_URL=https://your-claude-compatible-gateway/v1
# CLAUDE_API_KEY=YOUR_CLAUDE_KEY
# CLAUDE_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=YOUR_MILVUS_PASSWORD

INGEST_TOKEN=dev-ingest-token
# 10.04：与 ai-bff 共享的服务间密钥（只放服务端，勿进前端）
INTERNAL_TOKEN=dev-internal-token
# local = 本机 fastembed（默认可跑通中文）；openai = OpenAI 兼容网关（智谱/讯飞等）
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# 若 EMBEDDING_PROVIDER=openai，再配下面三项（也可用 ZHIPUAI_API_KEY + 智谱默认地址）
# EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# EMBEDDING_API_KEY=你的Embedding密钥
# EMBEDDING_MODEL=embedding-3
