APP_NAME=ai-service
APP_PORT=8091
DEFAULT_LLM=glm
ZHIPUAI_API_KEY=YOUR_API_KEY
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=YOUR_MILVUS_PASSWORD
# OpenAI 兼容：讯飞星火 MaaS Coding Plan（以你控制台为准）
OPENAI_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
OPENAI_API_KEY=你的完整APIKey
OPENAI_MODEL=sensen-code-latest

# —— Embedding（02.03）：必须用真模型，禁止伪向量 ——
# local = 本机 fastembed（默认可跑通中文）；openai = OpenAI 兼容网关（智谱/讯飞等）
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# 若 EMBEDDING_PROVIDER=openai，再配下面三项（也可用 ZHIPUAI_API_KEY + 智谱默认地址）
# EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# EMBEDDING_API_KEY=你的Embedding密钥
# EMBEDDING_MODEL=embedding-3